#!/bin/bash
#SBATCH --job-name=show_img_generation  # Job name
#SBATCH --nodes=1                  # Number of nodes
#SBATCH --ntasks=1                 # Number of tasks
#SBATCH --gres=gpu:1               # Number of GPUs per node
#SBATCH --cpus-per-task=4          # CPU cores per task
#SBATCH --mem=64G                  # Memory per node
#SBATCH --exclusive
#SBATCH --time=10:00:00            # Time limit (1 hour)
#SBATCH --mail-type=end          # send email when job ends
#SBATCH --mail-type=fail         # send email if job fails
#SBATCH --mail-user=rm4411@princeton.edu
#SBATCH --output=logs/%j/output.log
#SBATCH --error=logs/%j/error.log
#SBATCH --partition=all

# the first argument is the prompt
module purge
module load anaconda3/2024.02
source ~/.bashrc
conda activate show2
CONDA_LIB_PATH="/n/fs/vision-mix/rm4411/conda_envs/show2/lib"
export LD_LIBRARY_PATH="$CONDA_LIB_PATH:$LD_LIBRARY_PATH"

python3 inference_t2i.py config=configs/showo2_7b_demo_432x432.yaml prompt="/n/fs/vision-mix/rm4411/GENAIBENCH.csv" save_dir="/n/fs/vision-mix/rm4411/images/show-o2" \
                         batch_size=1 guidance_scale=7.5 num_inference_steps=50;
